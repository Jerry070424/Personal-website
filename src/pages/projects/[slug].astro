---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <article class="max-w-3xl mx-auto px-6 py-24">
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-text-primary mb-4">{project.data.title}</h1>
      <div class="flex items-center gap-4 text-sm text-text-muted mb-4">
        <time>{project.data.pubDate.toLocaleDateString("zh-CN")}</time>
      </div>
      <div class="flex gap-2 flex-wrap">
        {project.data.tags.map((tag) => (
          <span class="px-2 py-1 text-xs rounded-lg bg-cream text-accent">{tag}</span>
        ))}
      </div>
    </header>

    <div class="prose max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
