---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
projects.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="项目">
  <div class="max-w-5xl mx-auto px-6 py-24">
    <div class="relative mb-16">
      <div class="absolute -top-12 -left-12 w-64 h-64 rounded-full bg-orb-amber/25 blur-3xl pointer-events-none"></div>
      <h1 class="text-4xl font-bold text-accent relative z-10">项目</h1>
      <p class="text-text-secondary mt-3 relative z-10">我的作品集。</p>
    </div>

    {
      projects.length > 0 ? (
        <div class="grid md:grid-cols-2 gap-6">
          {projects.map((project) => (
            <a
              href={`/projects/${project.id}`}
              class="group block p-6 rounded-xl border border-border bg-surface shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300"
            >
              <div class="w-8 h-1 rounded-full bg-accent/20 group-hover:bg-accent/40 transition-colors mb-4"></div>
              <h2 class="text-xl font-semibold text-text-primary mb-2 group-hover:text-accent transition-colors">
                {project.data.title}
              </h2>
              <p class="text-text-secondary text-sm mb-4">{project.data.description}</p>
              <div class="flex gap-2 flex-wrap">
                {project.data.tags.map((tag) => (
                  <span class="px-2 py-1 text-xs rounded-lg bg-cream text-accent">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-text-muted text-center py-12">还没有项目。</p>
      )
    }
  </div>
</BaseLayout>
