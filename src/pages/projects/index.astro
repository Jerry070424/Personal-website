---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
projects.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="项目">
  <div class="max-w-5xl mx-auto px-6 py-24">
    <h1 class="text-4xl font-bold mb-4">
      <span class="bg-gradient-to-r from-accent-cyan to-accent-purple bg-clip-text text-transparent">
        项目
      </span>
    </h1>
    <p class="text-gray-400 mb-12">我的作品集。</p>

    {
      projects.length > 0 ? (
        <div class="grid md:grid-cols-2 gap-6">
          {projects.map((project) => (
            <a
              href={`/projects/${project.id}`}
              class="block p-6 rounded-xl border border-white/5 bg-dark-800/50 hover:border-accent-purple/30 transition-all duration-300 group"
            >
              <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-accent-purple transition-colors">
                {project.data.title}
              </h2>
              <p class="text-gray-400 text-sm mb-4">{project.data.description}</p>
              <div class="flex gap-2 flex-wrap">
                {project.data.tags.map((tag) => (
                  <span class="px-2 py-1 text-xs rounded bg-dark-600 text-accent-purple">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-gray-500 text-center py-12">还没有项目。</p>
      )
    }
  </div>
</BaseLayout>
