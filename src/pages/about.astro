---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
---

<BaseLayout title="关于">
  <div class="max-w-4xl mx-auto px-6 py-24">
    <!-- 页头光斑 -->
    <div class="relative mb-16">
      <div
        class="absolute -top-12 -left-12 w-80 h-80 pointer-events-none"
        style="background: radial-gradient(circle, rgba(220,232,245,0.4) 0%, rgba(220,232,245,0.1) 40%, transparent 70%);"
      ></div>
      <h1 class="text-4xl font-bold text-accent relative z-10">关于我</h1>
    </div>

    <!-- Bio Card -->
    <div class="p-8 rounded-xl border border-border bg-surface shadow-sm mb-16">
      <h2 class="text-2xl font-bold text-text-primary mb-4">{siteConfig.author.name}</h2>
      <p class="text-text-secondary mb-6">{siteConfig.author.bio}</p>
      <p class="text-text-secondary leading-relaxed">
        热爱编程、经济学和跨学科思考。相信技术可以改变世界，也相信理解人性才能做出真正有用的产品。
        在南京大学攻读双学位，希望用软件工程的思维解决经济问题，用经济学的视角优化技术决策。
      </p>
    </div>

    <!-- Timeline -->
    <div class="flex items-center gap-4 mb-8">
      <span class="h-px w-8 bg-accent/30"></span>
      <h2 class="text-sm font-mono text-text-muted tracking-widest uppercase">Experience</h2>
    </div>
    <div class="space-y-8">
      <div class="relative pl-8 border-l border-border">
        <div class="absolute left-0 top-1 w-3 h-3 -translate-x-1.5 rounded-full bg-accent shadow-sm" />
        <h3 class="text-lg font-semibold text-text-primary">南京大学</h3>
        <p class="text-sm text-accent mb-1">软件工程 & 经济学 双学位</p>
        <p class="text-sm text-text-muted">2025 – 2028</p>
      </div>
    </div>
  </div>
</BaseLayout>
