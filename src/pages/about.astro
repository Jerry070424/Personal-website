---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
---

<BaseLayout title="关于">
  <div class="max-w-4xl mx-auto px-6 py-24">
    <h1 class="text-4xl font-bold mb-12">
      <span class="bg-gradient-to-r from-accent-cyan to-accent-purple bg-clip-text text-transparent">
        关于我
      </span>
    </h1>

    <!-- Bio Card -->
    <div class="p-8 rounded-xl border border-white/5 bg-dark-800/50 mb-12">
      <h2 class="text-2xl font-bold text-white mb-4">{siteConfig.author.name}</h2>
      <p class="text-gray-400 mb-6">{siteConfig.author.bio}</p>
      <p class="text-gray-400 leading-relaxed">
        热爱编程、经济学和跨学科思考。相信技术可以改变世界，也相信理解人性才能做出真正有用的产品。
        在南京大学攻读双学位，希望用软件工程的思维解决经济问题，用经济学的视角优化技术决策。
      </p>
    </div>

    <!-- Timeline -->
    <h2 class="text-2xl font-bold text-white mb-8">经历</h2>
    <div class="space-y-8">
      <div class="relative pl-8 border-l border-white/10">
        <div class="absolute left-0 top-1 w-3 h-3 -translate-x-1.5 rounded-full bg-accent-cyan" />
        <h3 class="text-lg font-semibold text-white">南京大学</h3>
        <p class="text-sm text-accent-cyan mb-1">软件工程 & 经济学 双学位</p>
        <p class="text-sm text-gray-500">2025 – 2028</p>
      </div>
    </div>
  </div>
</BaseLayout>
