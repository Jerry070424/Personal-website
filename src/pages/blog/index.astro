---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="博客">
  <div class="max-w-4xl mx-auto px-6 py-24">
    <h1 class="text-4xl font-bold mb-4">
      <span class="bg-gradient-to-r from-accent-cyan to-accent-purple bg-clip-text text-transparent">
        博客
      </span>
    </h1>
    <p class="text-gray-400 mb-12">记录学习与思考。</p>

    {
      posts.length > 0 ? (
        <div class="space-y-6">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="block p-6 rounded-xl border border-white/5 bg-dark-800/50 hover:border-accent-cyan/30 transition-all duration-300 group"
            >
              <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-accent-cyan transition-colors">
                {post.data.title}
              </h2>
              <p class="text-gray-400 text-sm mb-3">{post.data.description}</p>
              <div class="flex items-center gap-4 text-xs text-gray-500">
                <time>{post.data.pubDate.toLocaleDateString("zh-CN")}</time>
                <div class="flex gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="px-2 py-0.5 rounded bg-dark-600 text-accent-cyan">{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-gray-500 text-center py-12">还没有文章。</p>
      )
    }
  </div>
</BaseLayout>
