---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="博客">
  <div class="max-w-4xl mx-auto px-6 py-24">
    <div class="relative mb-16">
      <div class="absolute -top-12 -left-12 w-64 h-64 rounded-full bg-orb-teal/25 blur-3xl pointer-events-none"></div>
      <h1 class="text-4xl font-bold text-accent relative z-10">博客</h1>
      <p class="text-text-secondary mt-3 relative z-10">记录学习与思考。</p>
    </div>

    {
      posts.length > 0 ? (
        <div class="space-y-4">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group block p-6 rounded-xl border border-border bg-surface shadow-sm hover:shadow-md hover:border-accent/20 transition-all duration-300"
            >
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  <h2 class="text-xl font-semibold text-text-primary mb-2 group-hover:text-accent transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="text-text-secondary text-sm mb-3">{post.data.description}</p>
                  <div class="flex items-center gap-3 text-xs text-text-muted">
                    <time>{post.data.pubDate.toLocaleDateString("zh-CN")}</time>
                    <span>·</span>
                    <div class="flex gap-1.5">
                      {post.data.tags.map((tag) => (
                        <span>{tag}</span>
                      ))}
                    </div>
                  </div>
                </div>
                <span class="text-text-muted text-lg group-hover:text-accent group-hover:translate-x-1 transition-all mt-1">→</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-text-muted text-center py-12">还没有文章。</p>
      )
    }
  </div>
</BaseLayout>
