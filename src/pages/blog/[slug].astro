---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="max-w-3xl mx-auto px-6 py-24">
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-white mb-4">{post.data.title}</h1>
      <div class="flex items-center gap-4 text-sm text-gray-500">
        <time>{post.data.pubDate.toLocaleDateString("zh-CN")}</time>
        <div class="flex gap-2">
          {post.data.tags.map((tag) => (
            <span class="px-2 py-0.5 rounded bg-dark-600 text-accent-cyan">{tag}</span>
          ))}
        </div>
      </div>
    </header>

    <div class="prose prose-invert max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
