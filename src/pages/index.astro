---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import ScrollReveal from "@/components/ScrollReveal.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const recentPosts = posts.slice(0, 3);

const projects = await getCollection("projects");
projects.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const featuredProjects = projects.slice(0, 4);
---

<BaseLayout>
  <div class="max-w-5xl mx-auto px-6">
    <!-- ─── Hero ─── -->
    <section class="min-h-[calc(100vh-4rem)] flex flex-col justify-center relative overflow-hidden">
      <!-- 柔和光斑 -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div
          class="absolute -top-32 -right-32 w-[700px] h-[700px] animate-orb-float"
          style="background: radial-gradient(circle, rgba(245,230,211,0.5) 0%, rgba(245,230,211,0.15) 40%, transparent 70%);"
        />
        <div
          class="absolute -bottom-48 -left-32 w-[600px] h-[600px] animate-orb-float"
          style="animation-delay: 2s; background: radial-gradient(circle, rgba(220,232,245,0.45) 0%, rgba(220,232,245,0.12) 40%, transparent 70%);"
        />
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] animate-orb-float"
          style="animation-delay: 4s; background: radial-gradient(circle, rgba(213,236,232,0.35) 0%, rgba(213,236,232,0.08) 40%, transparent 70%);"
        />
      </div>

      <div class="relative z-10">
        <img
          src={`${import.meta.env.BASE_URL}avatar.jpg`}
          alt={siteConfig.author.name}
          class="w-24 h-24 rounded-full object-cover border-2 border-border shadow-md mb-6"
        />
        <p class="text-text-secondary font-mono text-sm mb-4 tracking-widest uppercase">Hello, I'm</p>
        <h1 class="text-5xl md:text-8xl font-bold leading-tight mb-6 text-accent tracking-tight">
          {siteConfig.author.name}
        </h1>
        <p class="text-lg md:text-xl text-text-secondary max-w-2xl mb-8 leading-relaxed">
          {siteConfig.author.bio}
          <br />
          代码、经济学、以及一切有趣的事物。
        </p>
        <div class="flex gap-4">
          <a
            href="/about"
            class="px-6 py-3 rounded-xl bg-accent text-white font-medium hover:bg-accent-hover transition-colors shadow-sm"
          >
            了解更多 →
          </a>
          <a
            href="/blog"
            class="px-6 py-3 rounded-xl border border-border text-text-secondary hover:border-accent hover:text-accent hover:bg-accent-soft/50 transition-all"
          >
            阅读博客
          </a>
        </div>
      </div>
    </section>

    <!-- ─── About ─── -->
    <ScrollReveal>
      <section class="py-24">
        <div class="flex items-center gap-4 mb-12">
          <span class="h-px flex-1 bg-border-light"></span>
          <h2 class="text-sm font-mono text-text-muted tracking-widest uppercase">About</h2>
          <span class="h-px flex-1 bg-border-light"></span>
        </div>
        <div class="max-w-2xl mx-auto text-center">
          <p class="text-text-secondary text-lg leading-relaxed mb-8">
            南京大学软件工程与经济学双学位大一学生。热爱编程、经济学和跨学科思考。
            相信技术可以改变世界，也相信理解人性才能做出真正有用的产品。
          </p>
          <div class="flex justify-center gap-12 text-sm">
            <div class="text-center">
              <div class="text-3xl font-bold text-text-primary mb-1">NJU</div>
              <div class="text-text-muted text-xs">学校</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-text-primary mb-1">SE & Econ</div>
              <div class="text-text-muted text-xs">专业</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-text-primary mb-1">2028</div>
              <div class="text-text-muted text-xs">毕业</div>
            </div>
          </div>
        </div>
      </section>
    </ScrollReveal>

    <!-- ─── Projects ─── -->
    <ScrollReveal>
      <section class="py-24">
        <div class="flex items-center justify-between mb-12">
          <div class="flex items-center gap-4">
            <span class="h-px w-8 bg-accent/30"></span>
            <h2 class="text-sm font-mono text-text-muted tracking-widest uppercase">Projects</h2>
          </div>
          <a href="/projects" class="text-sm text-text-secondary hover:text-accent transition-colors">
            查看全部 →
          </a>
        </div>
        {
          featuredProjects.length > 0 ? (
            <div class="grid md:grid-cols-2 gap-6">
              {featuredProjects.map((project) => (
                <a
                  href={`/projects/${project.id}`}
                  class="group block p-6 rounded-xl border border-border bg-surface shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300"
                >
                  <div class="w-8 h-1 rounded-full bg-accent/20 group-hover:bg-accent/40 transition-colors mb-4"></div>
                  <h3 class="text-lg font-semibold text-text-primary mb-2 group-hover:text-accent transition-colors">
                    {project.data.title}
                  </h3>
                  <p class="text-text-secondary text-sm leading-relaxed mb-4">{project.data.description}</p>
                  <div class="flex gap-2 flex-wrap">
                    {project.data.tags.map((tag) => (
                      <span class="px-2 py-1 text-xs rounded-lg bg-cream text-accent">{tag}</span>
                    ))}
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="text-center py-12">
              <p class="text-text-muted">还没有项目。</p>
            </div>
          )
        }
      </section>
    </ScrollReveal>

    <!-- ─── Blog ─── -->
    <ScrollReveal>
      <section class="py-24">
        <div class="flex items-center justify-between mb-12">
          <div class="flex items-center gap-4">
            <span class="h-px w-8 bg-accent/30"></span>
            <h2 class="text-sm font-mono text-text-muted tracking-widest uppercase">Writing</h2>
          </div>
          <a href="/blog" class="text-sm text-text-secondary hover:text-accent transition-colors">
            全部文章 →
          </a>
        </div>
        {
          recentPosts.length > 0 ? (
            <div class="space-y-4">
              {recentPosts.map((post) => (
                <a
                  href={`/blog/${post.id}`}
                  class="group block p-5 rounded-xl border border-border bg-surface shadow-sm hover:shadow-md hover:border-accent/20 transition-all duration-300"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-1">
                      <h3 class="text-lg font-semibold text-text-primary mb-1 group-hover:text-accent transition-colors">
                        {post.data.title}
                      </h3>
                      <p class="text-text-secondary text-sm mb-2">{post.data.description}</p>
                      <div class="flex items-center gap-3 text-xs text-text-muted">
                        <time>{post.data.pubDate.toLocaleDateString("zh-CN")}</time>
                        <span>·</span>
                        <div class="flex gap-1.5">
                          {post.data.tags.map((tag) => (
                            <span>{tag}</span>
                          ))}
                        </div>
                      </div>
                    </div>
                    <span class="text-text-muted text-lg group-hover:text-accent group-hover:translate-x-1 transition-all mt-1">→</span>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="text-center py-12">
              <p class="text-text-muted">还没有文章。开始写第一篇吧！</p>
            </div>
          )
        }
      </section>
    </ScrollReveal>

    <!-- ─── Contact ─── -->
    <ScrollReveal>
      <section class="py-24 text-center">
        <div class="flex items-center gap-4 mb-12">
          <span class="h-px flex-1 bg-border-light"></span>
          <h2 class="text-sm font-mono text-text-muted tracking-widest uppercase">Contact</h2>
          <span class="h-px flex-1 bg-border-light"></span>
        </div>
        <p class="text-text-secondary mb-8">
          如果有任何想法或合作意向，欢迎通过 GitHub 联系我。
        </p>
        <a
          href={siteConfig.social[0].url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-3 rounded-xl bg-accent text-white font-medium hover:bg-accent-hover transition-colors shadow-sm"
        >
          GitHub
        </a>
      </section>
    </ScrollReveal>
  </div>
</BaseLayout>

<style>
  @keyframes orb-float {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(20px, -30px) scale(1.05);
    }
    66% {
      transform: translate(-15px, 20px) scale(0.95);
    }
  }
  .animate-orb-float {
    animation: orb-float 10s ease-in-out infinite;
  }
</style>
