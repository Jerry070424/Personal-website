---
import { siteConfig } from "@/config/site";
import "@/styles/global.css";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN" transition:slide>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} | ${siteConfig.title}` : siteConfig.title}</title>
    <meta name="description" content={description || siteConfig.description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen">
    <!-- Nav -->
    <header
      id="navbar"
      class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl border-b border-border transition-all duration-300"
      style="background: rgba(250, 249, 245, 0.85)"
    >
      <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
        <a
          href={import.meta.env.BASE_URL}
          class="text-lg font-bold text-accent hover:opacity-80 transition-opacity"
        >
          {siteConfig.author.name}
        </a>
        <div class="flex items-center gap-8 text-sm text-text-secondary">
          {
            siteConfig.nav.map((item) => (
              <a
                href={`${import.meta.env.BASE_URL}${item.href}`}
                class="hover:text-accent transition-colors duration-200 relative group"
              >
                {item.label}
                <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-accent transition-all duration-300 group-hover:w-full" />
              </a>
            ))
          }
        </div>
      </nav>
    </header>

    <!-- Main -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-border py-12 mt-24">
      <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-text-muted">
        <p>&copy; {new Date().getFullYear()} {siteConfig.author.name}. All rights reserved.</p>
        <div class="flex items-center gap-4">
          {
            siteConfig.social.map((s) => (
              <a
                href={s.url.startsWith("http") ? s.url : `${import.meta.env.BASE_URL}${s.url}`}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-accent transition-colors duration-200"
              >
                {s.name}
              </a>
            ))
          }
        </div>
      </div>
    </footer>
  </body>
</html>

<script>
  // Navbar hide/show on scroll direction
  let lastScroll = 0;
  const navbar = document.getElementById("navbar");

  window.addEventListener("scroll", () => {
    const currentScroll = window.scrollY;
    if (currentScroll > lastScroll && currentScroll > 80) {
      navbar.style.transform = "translateY(-100%)";
    } else {
      navbar.style.transform = "translateY(0)";
    }
    lastScroll = currentScroll;
  });
</script>
